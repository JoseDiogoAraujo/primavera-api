        "targets": [
          {
            "format": "table",
            "rawSql": "SELECT\n  SUM(CASE WHEN cd.TipoDoc IN ('FA','FAC','FR','GT') THEN (cd.TotalDocumento - cd.TotalIva) WHEN cd.TipoDoc IN ('ALC','ALI','FAA','NC') THEN -(cd.TotalDocumento - cd.TotalIva) ELSE 0 END) as total\nFROM CabecDoc cd\nINNER JOIN CabecDocStatus cds ON cd.Id = cds.IdCabecDoc AND cds.Anulado = 0\nWHERE cd.TipoDoc IN ('FA','FAC','FR','GT','ALC','ALI','FAA','NC')\n  AND $__timeFilter(cd.Data)",
            "refId": "A"
          }
        ],
        "title": "Total Facturado (Descarga)",
        "type": "stat"
