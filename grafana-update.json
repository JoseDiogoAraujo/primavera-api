        "targets": [
          {
            "format": "time_series",
            "rawSql": "SELECT\n  DATEADD(MONTH, DATEDIFF(MONTH, 0, cd.Data), 0) as time,\n  SUM(CASE WHEN cd.TipoDoc IN ('FA','FAC','FR','GT') THEN (cd.TotalDocumento - cd.TotalIva) WHEN cd.TipoDoc IN ('ALC','ALI','FAA','NC') THEN -(cd.TotalDocumento - cd.TotalIva) ELSE 0 END) as 'Total Vendas'\nFROM CabecDoc cd\nINNER JOIN CabecDocStatus cds ON cd.Id = cds.IdCabecDoc AND cds.Anulado = 0\nWHERE cd.TipoDoc IN ('FA','FAC','FR','GT','ALC','ALI','FAA','NC')\n  AND $__timeFilter(cd.Data)\nGROUP BY DATEADD(MONTH, DATEDIFF(MONTH, 0, cd.Data), 0)\nORDER BY time",
            "refId": "A"
          }
        ],
        "title": "Evolucao Mensal de Vendas",
        "type": "timeseries"
